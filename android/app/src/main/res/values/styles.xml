<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema de splash para Android 12+ -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- mismo color para fondo y círculo -->
        <item name="windowSplashScreenBackground">@color/attune_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/attune_adaptive</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>

    <!-- Tema normal después del splash -->
    <style name="NormalTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">#FFFFFF</item>
    </style>
</resources>